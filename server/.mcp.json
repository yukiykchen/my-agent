{
  "mcpServers": {
    "weather": {
      "command": "./mcp-servers/weather/weather-server",
      "args": []
    },
    "screenshot": {
      "command": "./mcp-servers/screenshot/screenshot-server",
      "args": [],
      "env": {
        "SCREENSHOT_DIR": "./data/screenshots"
      }
    },
    "textcompare": {
      "command": "./mcp-servers/textcompare/textcompare-server",
      "args": []
    },
    "webcrawl": {
      "command": "./mcp-servers/webcrawl/webcrawl-server",
      "args": []
    },
    "webcompare": {
      "command": "./mcp-servers/webcompare/webcompare-server",
      "args": []
    },
    "tencent-docs": {
      "transport": "http",
      "baseUrl": "https://docs.qq.com/openapi/mcp",
      "headers": {
        "Authorization": "${TENCENT_DOCS_TOKEN}"
      }
    },
    "tencent-docengine": {
      "transport": "http",
      "baseUrl": "https://docs.qq.com/api/v6/doc/mcp",
      "headers": {
        "Authorization": "${TENCENT_DOCS_TOKEN}"
      }
    },
    "tencent-sheetengine": {
      "transport": "http",
      "baseUrl": "https://docs.qq.com/api/v6/sheet/mcp",
      "headers": {
        "Authorization": "${TENCENT_DOCS_TOKEN}"
      }
    }
  }
}
